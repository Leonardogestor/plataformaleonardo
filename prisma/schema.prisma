generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model InvestmentMovement {
  id           String       @id @default(cuid())
  investmentId String
  amount       Decimal      @db.Decimal(15, 2)
  type         MovementType
  date         DateTime     @default(now())
  createdAt    DateTime     @default(now())
  investment   Investment   @relation(fields: [investmentId], references: [id], onDelete: Cascade)

  @@index([investmentId])
  @@map("investment_movements")
}

model Card {
  id               String             @id @default(cuid())
  userId           String
  name             String
  lastFourDigits   String             @db.VarChar(4)
  brand            String
  limit            Decimal            @db.Decimal(15, 2)
  closingDay       Int
  dueDay           Int
  color            String?
  isActive         Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  financial_ledger financial_ledger[]
  transactions     Transaction[]

  @@index([userId])
  @@map("cards")
}

model Budget {
  id        String   @id @default(cuid())
  userId    String
  category  String
  month     String
  amount    Decimal  @db.Decimal(15, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, month], name: "userId_category_month")
  @@index([userId, month])
  @@index([userId, category, month], map: "budget_user_category_month_idx")
  @@map("budgets")
}

model User {
  id                     String                    @id @default(cuid())
  name                   String
  email                  String                    @unique
  password               String
  role                   UserRole                  @default(USER)
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  accounts               Account[]
  bankConnections        BankConnection[]
  budgets                Budget[]
  cards                  Card[]
  categorizationRules    CategoryRule[]
  documents              Document[]
  financial_ledger       financial_ledger[]
  financial_snapshots    financial_snapshots[]
  goals                  Goal[]
  governanceChecklist    GovernanceChecklistItem[]
  investments            Investment[]
  transactions           Transaction[]
  subscriptions          Subscription[]
  featureAccess          FeatureAccess[]
  passwordSetupTokens    PasswordSetupToken[]
  anamnesis              UserAnamnesis?
  rawTransactions        RawTransaction[]
  parsedTransactions     ParsedTransaction[]
  normalizedTransactions NormalizedTransaction[]
  merchantMappings       MerchantMapping[]

  @@map("users")
}

model Document {
  id              String                    @id @default(cuid())
  userId          String
  name            String
  fileName        String
  mimeType        String
  filePath        String?
  createdAt       DateTime                  @default(now())
  extractedText   String?
  vencimentoAt    DateTime?
  updatedAt       DateTime                  @updatedAt
  fileSize        Int?
  fileUrl         String?
  fileKey         String?
  status          DocumentStatus            @default(PROCESSING)
  errorMessage    String?
  syncLogs        SyncLog[]
  transactions    Transaction[]
  governanceItems GovernanceChecklistItem[]
  user            User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("documents")
}

model SyncLog {
  id                    String    @id @default(cuid())
  itemId                String?
  documentId            String?
  startedAt             DateTime
  finishedAt            DateTime?
  durationMs            Int?
  transactionsProcessed Int?
  status                String
  error                 String?
  createdAt             DateTime  @default(now())
  document              Document? @relation(fields: [documentId], references: [id])

  @@index([itemId])
  @@index([documentId])
  @@index([createdAt])
  @@map("sync_logs")
}

model GovernanceChecklistItem {
  id          String    @id @default(cuid())
  userId      String
  year        Int
  itemKey     String
  itemLabel   String
  completedAt DateTime?
  documentId  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  document    Document? @relation(fields: [documentId], references: [id])
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year, itemKey], name: "userId_year_itemKey")
  @@index([userId, year])
  @@map("governance_checklist_items")
}

model BankConnection {
  id               String           @id @default(cuid())
  userId           String
  provider         BankProvider     @default(PLUGGY)
  itemId           String           @unique
  status           ConnectionStatus @default(ACTIVE)
  error            String?
  consentExpiresAt DateTime?
  lastSyncAt       DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  isSyncing        Boolean          @default(false)
  accounts         Account[]
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([itemId])
  @@index([itemId, isSyncing])
  @@map("bank_connections")
}

model Account {
  id                String             @id @default(cuid())
  userId            String
  connectionId      String?
  externalAccountId String?            @unique
  name              String
  type              AccountType
  institution       String
  balance           Decimal            @db.Decimal(15, 2)
  currency          String             @default("BRL")
  color             String?
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  connection        BankConnection?    @relation(fields: [connectionId], references: [id])
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  financial_ledger  financial_ledger[]
  transactions      Transaction[]

  @@index([userId])
  @@index([connectionId])
  @@index([externalAccountId])
  @@map("accounts")
}

model Transaction {
  id                    String            @id @default(uuid())
  userId                String
  documentId            String?
  date                  DateTime
  description           String
  amount                Decimal           @db.Decimal(15, 2)
  type                  TransactionType
  category              String
  accountId             String?
  cardId                String?
  installmentGroupId    String?
  totalInstallments     Int?
  currentInstallment    Int?
  installmentValue      Decimal?
  externalTransactionId String?           @unique
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  isPending             Boolean?          @default(false)
  subcategory           String?
  status                String?           @default("ACTIVE")
  account               Account?          @relation(fields: [accountId], references: [id])
  card                  Card?             @relation(fields: [cardId], references: [id])
  document              Document?         @relation(fields: [documentId], references: [id])
  installmentGroup      InstallmentGroup? @relation(fields: [installmentGroupId], references: [id])
  user                  User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, amount, description])
  @@index([userId])
  @@index([documentId])
  @@index([accountId])
  @@index([cardId])
  @@index([date])
  @@index([installmentGroupId])
  @@map("transactions")
}

model InstallmentGroup {
  id                String        @id @default(uuid())
  userId            String
  cardId            String
  description       String
  totalValue        Decimal       @db.Decimal(15, 2)
  totalInstallments Int
  startDate         DateTime
  createdAt         DateTime      @default(now())
  transactions      Transaction[]
}

model Goal {
  id            String             @id @default(cuid())
  userId        String
  name          String
  description   String?
  targetAmount  Decimal            @db.Decimal(15, 2)
  currentAmount Decimal            @default(0) @db.Decimal(15, 2)
  deadline      DateTime
  category      String
  status        GoalStatus         @default(ACTIVE)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  contributions GoalContribution[]
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("goals")
}

model GoalContribution {
  id        String   @id @default(cuid())
  goalId    String
  amount    Decimal  @db.Decimal(15, 2)
  date      DateTime @default(now())
  note      String?
  createdAt DateTime @default(now())
  goal      Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
  @@map("goal_contributions")
}

model Investment {
  id               String               @id @default(cuid())
  userId           String
  name             String
  type             InvestmentType
  amount           Decimal              @db.Decimal(15, 2)
  currentValue     Decimal              @db.Decimal(15, 2)
  quantity         Decimal?             @db.Decimal(15, 6)
  institution      String
  ticker           String?
  acquiredAt       DateTime
  maturityDate     DateTime?
  profitability    Decimal?             @db.Decimal(8, 4)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  financial_ledger financial_ledger[]
  movements        InvestmentMovement[]
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("investments")
}

model CategoryRule {
  id            String   @id @default(cuid())
  userId        String
  pattern       String
  category      String
  matchCount    Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  conditionJson String?
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, pattern])
  @@index([userId])
  @@map("category_rules")
}

model financial_ledger {
  id              String           @id
  userId          String
  eventType       LedgerEventType
  entityType      LedgerEntityType
  entityId        String
  amount          Decimal          @db.Decimal(15, 2)
  currency        String           @default("BRL")
  accountId       String?
  investmentId    String?
  cardId          String?
  eventTimestamp  DateTime         @default(now())
  sequenceNumber  BigInt           @default(0)
  previousBalance Decimal?         @db.Decimal(15, 2)
  newBalance      Decimal?         @db.Decimal(15, 2)
  description     String?
  metadata        Json?
  externalId      String?
  source          LedgerSource
  isReversed      Boolean          @default(false)
  reversedBy      String?
  reversalReason  String?
  createdAt       DateTime         @default(now())
  processedAt     DateTime?
  accounts        Account?         @relation(fields: [accountId], references: [id])
  cards           Card?            @relation(fields: [cardId], references: [id])
  investments     Investment?      @relation(fields: [investmentId], references: [id])
  users           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sequenceNumber])
  @@index([createdAt])
  @@index([eventTimestamp])
  @@index([eventType, entityId])
  @@index([userId])
  @@index([userId, sequenceNumber])
}

model financial_snapshots {
  id                 String   @id
  userId             String
  snapshotDate       DateTime @db.Date
  totalAssets        Decimal  @db.Decimal(15, 2)
  totalLiabilities   Decimal  @default(0) @db.Decimal(15, 2)
  netWorth           Decimal  @db.Decimal(15, 2)
  cashBalance        Decimal  @default(0) @db.Decimal(15, 2)
  investmentValue    Decimal  @default(0) @db.Decimal(15, 2)
  receivables        Decimal  @default(0) @db.Decimal(15, 2)
  periodIncome       Decimal  @default(0) @db.Decimal(15, 2)
  periodExpense      Decimal  @default(0) @db.Decimal(15, 2)
  periodSavings      Decimal  @default(0) @db.Decimal(15, 2)
  savingsRate        Decimal  @default(0) @db.Decimal(6, 4)
  financialScore     Int?
  riskLevel          String?
  lastLedgerSequence BigInt
  calculationVersion Int      @default(1)
  createdAt          DateTime @default(now())
  updatedAt          DateTime
  users              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, snapshotDate])
  @@index([createdAt])
  @@index([userId, snapshotDate])
}

model user_ledger_sequences {
  userId       String @id
  lastSequence BigInt @default(0)
}

enum MovementType {
  APORTE
  RETIRADA
}

enum DocumentStatus {
  PROCESSING
  COMPLETED
  FAILED
}

enum UserRole {
  ADMIN
  USER
}

enum AccountType {
  CHECKING
  SAVINGS
  INVESTMENT
  CASH
  OTHER
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  PAUSED
}

enum InvestmentType {
  STOCKS
  BONDS
  REAL_ESTATE
  FIXED_INCOME
  CRYPTO
  FUNDS
  OTHER
  INTERNATIONAL
}

enum BankProvider {
  PLUGGY
  BELVO
  MANUAL
}

enum ConnectionStatus {
  ACTIVE
  UPDATING
  LOGIN_ERROR
  OUTDATED
  DISCONNECTED
}

enum LedgerEntityType {
  TRANSACTION
  INVESTMENT
  ACCOUNT
  CARD
  BUDGET
  GOAL
  SYSTEM
}

enum LedgerEventType {
  TRANSACTION_DEBIT
  TRANSACTION_CREDIT
  INVESTMENT_BUY
  INVESTMENT_SELL
  INVESTMENT_DIVIDEND
  ACCOUNT_TRANSFER_DEBIT
  ACCOUNT_TRANSFER_CREDIT
  CARD_PAYMENT
  CARD_PAYMENT_REFUND
  BUDGET_ALLOCATION
  BUDGET_CONSUMPTION
  GOAL_CONTRIBUTION
  GOAL_WITHDRAWAL
  CORRECTION
  REVERSAL
}

enum LedgerSource {
  USER_INPUT
  OPEN_FINANCE_SYNC
  BANK_IMPORT
  SYSTEM_CALCULATION
  CORRECTION
  MIGRATION
}

model Subscription {
  id               String             @id @default(cuid())
  userId           String
  kiwifyId         String?            @unique
  status           SubscriptionStatus @default(INACTIVE)
  plan             SubscriptionPlan   @default(FREE)
  currentPeriodEnd DateTime?
  canceledAt       DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([kiwifyId])
  @@map("subscriptions")
}

model FeatureAccess {
  id              String    @id @default(cuid())
  userId          String
  feature         String
  isActive        Boolean   @default(false)
  accessExpiresAt DateTime?
  source          String    @default("system")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, feature])
  @@index([userId])
  @@index([accessExpiresAt])
  @@map("feature_access")
}

model ProcessedWebhookEvent {
  id             String   @id @default(cuid())
  eventId        String   @unique
  eventType      String
  status         String   @default("pending")
  processedAt    DateTime @default(now())
  errorMessage   String?
  userId         String?
  orderId        String?
  subscriptionId String?
  metadata       Json?

  @@index([eventId])
  @@index([eventType])
  @@index([status])
  @@map("processed_webhook_events")
}

model PasswordSetupToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([email])
  @@index([expiresAt])
  @@map("password_setup_tokens")
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  CANCELED
  EXPIRED
  PENDING
  PAST_DUE
  TRAILING
}

enum SubscriptionPlan {
  FREE
  PREMIUM
  PRO
}

model UserAnamnesis {
  id          String    @id @default(cuid())
  userId      String    @unique
  name        String? // Nome do usuário
  birthDate   DateTime? // Data de nascimento
  responses   Json // Respostas do formulário estratégico
  analysis    Json? // Análise e estratégias geradas pela IA
  profileType String? // Tipo de perfil: CONTROLE, RECUPERACAO, CRESCIMENTO
  riskLevel   String? // Nível de risco: CONSERVADOR, MODERADO, AGRESSIVO
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_anamnesis")
}

model MerchantMapping {
  id             String   @id @default(cuid())
  userId         String
  rawDescription String
  merchant       String
  category       String
  subcategory    String?
  usageCount     Int      @default(1)
  confidence     Float    @default(0.9)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, rawDescription])
  @@index([userId])
  @@index([rawDescription])
  @@map("merchant_mappings")
}

model RawTransaction {
  id        String   @id @default(cuid())
  userId    String
  source    String
  rawText   String?
  rawJson   Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("raw_transactions")
}

model ParsedTransaction {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime
  description String
  amount      Decimal  @db.Decimal(15, 2)
  type        String
  confidence  Float
  rawId       String
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([rawId])
  @@index([date])
  @@map("parsed_transactions")
}

model NormalizedTransaction {
  id                      String   @id @default(cuid())
  userId                  String
  parsedId                String
  merchant                String
  category                String
  subcategory             String?
  standardizedDescription String
  confidence              Float
  createdAt               DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([parsedId])
  @@index([category])
  @@map("normalized_transactions")
}
