{
  "buildCommand": "prisma generate && next build",
  "framework": "nextjs",
  "installCommand": "npm install --force --include=dev",
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 30
    },
    "app/api/documents/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "env": {
    "NEXT_TELEMETRY_DISABLED": "1"
  }
}
